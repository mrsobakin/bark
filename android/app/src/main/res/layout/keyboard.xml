<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="195dp"
    android:background="@drawable/bg_keyboard"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:clipChildren="false">

        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:clipChildren="false">

            <!-- Pulse circle – scales with audio amplitude -->
            <View
                android:id="@+id/levelIndicator"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_pulse"
                android:visibility="gone" />

            <!-- Transcribing spinner ring -->
            <ImageView
                android:id="@+id/transcribingIndicator"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_spinner"
                android:visibility="gone" />

            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:clickable="false">

                <ImageButton
                    android:id="@+id/recordButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_mic"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/tap_to_record"
                    android:scaleType="center"
                    android:importantForAccessibility="yes" />

            </FrameLayout>

        </FrameLayout>

    </LinearLayout>

</FrameLayout>
