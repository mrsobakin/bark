<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Bark" parent="android:Theme.Material.NoActionBar" />

    <style name="Theme.Bark.Settings" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorPrimary">@color/primary</item>
    </style>

    <style name="Theme.Bark.Translucent" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
