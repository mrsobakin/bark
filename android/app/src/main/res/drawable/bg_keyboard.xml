<?xml version="1.0" encoding="utf-8"?>
<!-- Layered gradients preserve the original soft transparent-to-black fade. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:centerColor="#FF000000"
                android:centerY="0.3"
                android:endColor="#FF000000"
                android:startColor="#00000000" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:centerColor="#FF000000"
                android:centerY="0.3"
                android:endColor="#FF000000"
                android:startColor="#00000000" />
        </shape>
    </item>
</layer-list>
